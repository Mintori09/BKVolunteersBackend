model CampaignMedia {
  id         String            @id @default(uuid()) @db.Char(36)
  campaignId String            @db.Char(36)
  moduleId   String?           @db.Char(36)
  fileId     String            @db.Char(36)
  mediaType  CampaignMediaType
  caption    String?           @db.VarChar(500)
  isPublic   Boolean           @default(true)
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  module   CampaignModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  file     File            @relation("CampaignMediaFile", fields: [fileId], references: [id], onDelete: Restrict)

  @@index([campaignId])
  @@index([moduleId])
  @@map("campaign_media")
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model ManagerNotification {
  id         String                  @id @default(uuid()) @db.Char(36)
  managerId  String                  @db.Char(36)
  type       NotificationType
  title      String                  @db.VarChar(255)
  message    String                  @db.Text
  targetType NotificationTargetType?
  targetId   String?                 @db.Char(36)
  isRead     Boolean                 @default(false)
  createdAt  DateTime                @default(now())

  manager ManagerAccount @relation(fields: [managerId], references: [id], onDelete: Cascade)

  @@index([managerId, isRead])
  @@map("manager_notifications")
}

model StudentNotification {
  id         String                  @id @default(uuid()) @db.Char(36)
  studentId  String                  @db.Char(36)
  type       NotificationType
  title      String                  @db.VarChar(255)
  message    String                  @db.Text
  targetType NotificationTargetType?
  targetId   String?                 @db.Char(36)
  isRead     Boolean                 @default(false)
  createdAt  DateTime                @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, isRead])
  @@map("student_notifications")
}

//////////////////////////////////////////////////////
// AUTH (UNIFIED UNDER USERS)
//////////////////////////////////////////////////////

model UserOAuthAccount {
  id                String   @id @default(uuid()) @db.Char(36)
  userId            String   @db.Char(36)
  provider          String   @db.VarChar(50)
  providerAccountId String   @db.VarChar(255)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("user_oauth_accounts")
}

model UserRefreshToken {
  id        String    @id @default(uuid()) @db.Char(36)
  token     String    @unique @db.VarChar(255)
  userId    String    @db.Char(36)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_refresh_tokens")
}

model UserResetToken {
  id        String   @id @default(uuid()) @db.Char(36)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime
  userId    String   @db.Char(36)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_reset_tokens")
}

model UserEmailVerificationToken {
  id        String   @id @default(uuid()) @db.Char(36)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime
  userId    String   @db.Char(36)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_email_verification_tokens")
}
